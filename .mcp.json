{
  "mcpServers": {
    "sqlserver": {
      "command": "npx",
      "args": ["-y", "@ibergeni/mcp-sqlserver"],
      "env": {
        "SQLSERVER_AUTH_MODE": "${SQLSERVER_AUTH_MODE}",
        "SQLSERVER_HOST": "${SQLSERVER_HOST}",
        "SQLSERVER_PORT": "${SQLSERVER_PORT}",
        "SQLSERVER_DATABASE": "${SQLSERVER_DATABASE}",
        "SQLSERVER_USER": "${SQLSERVER_USER}",
        "SQLSERVER_PASSWORD": "${SQLSERVER_PASSWORD}",
        "SQLSERVER_CLIENT_ID": "${SQLSERVER_CLIENT_ID}",
        "SQLSERVER_CLIENT_SECRET": "${SQLSERVER_CLIENT_SECRET}",
        "SQLSERVER_TENANT_ID": "${SQLSERVER_TENANT_ID}",
        "SQLSERVER_ENCRYPT": "${SQLSERVER_ENCRYPT}",
        "SQLSERVER_TRUST_CERT": "${SQLSERVER_TRUST_CERT}",
        "SQLSERVER_SCHEMA_CACHE_PATH": "${SQLSERVER_SCHEMA_CACHE_PATH}",
        "SQLSERVER_DOMAIN_SOURCE_PATH": "${SQLSERVER_DOMAIN_SOURCE_PATH}"
      }
    }
  }
}
